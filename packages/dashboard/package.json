{
  "name": "@my-agent/dashboard",
  "version": "0.1.0",
  "description": "Web UI for my_agent — chat interface + hatching wizard",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --env-file=.env --import tsx/esm src/index.ts",
    "build": "npm run build:css && tsc",
    "build:css": "tailwindcss -c tailwind.config.cjs -i ./public/css/tailwind.input.css -o ./public/css/tailwind.css --minify",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write src/ public/",
    "format:check": "prettier --check src/ public/"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.39",
    "@anthropic-ai/sdk": "^0.74.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "@my-agent/channel-whatsapp": "file:../../plugins/channel-whatsapp",
    "@my-agent/core": "file:../core",
    "@playwright/mcp": "^0.0.68",
    "better-sqlite3": "^12.6.2",
    "cron-parser": "^5.5.0",
    "fastify": "^5.0.0",
    "pino-pretty": "^13.1.0",
    "sharp": "^0.34.5",
    "sqlite-vec": "^0.1.7-alpha.2",
    "ulid": "^2.3.0",
    "yaml": "^2.8.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.9",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
